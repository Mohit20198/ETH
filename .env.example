# ─────────────────────────────────────────────────────────────────────────────
# LLM Configuration
# ─────────────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...your-key-here...
OPENAI_MODEL=gpt-4o
OPENAI_VISION_MODEL=gpt-4o

# Alternative: Google Gemini
# GOOGLE_API_KEY=...
# GEMINI_MODEL=gemini-1.5-pro

# ─────────────────────────────────────────────────────────────────────────────
# Neo4j Graph Database
# ─────────────────────────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=industrialiq123

# ─────────────────────────────────────────────────────────────────────────────
# ChromaDB Vector Store
# ─────────────────────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION_NAME=industrialiq_docs

# ─────────────────────────────────────────────────────────────────────────────
# Embedding Model
# ─────────────────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=text-embedding-3-small
# Or local: SENTENCE_TRANSFORMERS_MODEL=all-MiniLM-L6-v2

# ─────────────────────────────────────────────────────────────────────────────
# Langfuse Eval Observability
# ─────────────────────────────────────────────────────────────────────────────
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=http://localhost:3001

# ─────────────────────────────────────────────────────────────────────────────
# Document Processing
# ─────────────────────────────────────────────────────────────────────────────
TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
DOC_UPLOAD_DIR=./data/uploads
DOC_FINGERPRINT_CACHE=./data/fingerprints.json

# ─────────────────────────────────────────────────────────────────────────────
# API
# ─────────────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ─────────────────────────────────────────────────────────────────────────────
# Retrieval Tuning
# ─────────────────────────────────────────────────────────────────────────────
VECTOR_TOP_K=10
GRAPH_HOP_LIMIT=3
RETRIEVAL_CONFIDENCE_THRESHOLD=0.70
RERANKER_VECTOR_WEIGHT=0.6
RERANKER_GRAPH_WEIGHT=0.4
